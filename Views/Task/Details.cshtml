@model Organizr.Models.TaskItem

@{
    ViewData["Title"] = "Task Details";
}

<div class="container py-5">

    <div class="row justify-content-center">

        <div class="col-lg-9">

            <div class="card shadow-lg border-0 rounded-4">

                <!-- Header -->

                <div class="card-header bg-primary text-white p-4 rounded-top-4">

                    <div class="d-flex justify-content-between align-items-center">

                        <div>

                            <h2 class="mb-1">

                                <i class="bi bi-journal-text me-2"></i>

                                Task Details

                            </h2>

                            <small>
                                Created on @Model.CreatedAt.ToString("dd MMM yyyy, hh:mm tt")
                            </small>

                        </div>

                        @if (Model.IsCompleted)
                        {
                            <span class="badge bg-success fs-6 px-3 py-2">

                                <i class="bi bi-check-circle-fill"></i>

                                Completed

                            </span>
                        }
                        else
                        {
                            <span class="badge bg-warning text-dark fs-6 px-3 py-2">

                                <i class="bi bi-clock-fill"></i>

                                Pending

                            </span>
                        }

                    </div>

                </div>

                <!-- Body -->

                <div class="card-body p-5">

                    <!-- Title -->

                    <div class="mb-4">

                        <label class="text-muted mb-2">

                            <i class="bi bi-type"></i>

                            Title

                        </label>

                        <h3 class="fw-bold">

                            @Model.Title

                        </h3>

                    </div>

                    <!-- Description -->

                    <div class="mb-5">

                        <label class="text-muted mb-2">

                            <i class="bi bi-card-text"></i>

                            Description

                        </label>

                        <div class="description-box">

                            @if (string.IsNullOrWhiteSpace(Model.Description))
                            {
                                <span class="text-muted">
                                    No description provided.
                                </span>
                            }
                            else
                            {
                                @Model.Description
                            }

                        </div>

                    </div>

                    <!-- Information -->

                    <div class="row text-center mb-5">

                        <div class="col-md-4">

                            <div class="info-card">

                                <i class="bi bi-calendar-event display-6 text-primary"></i>

                                <h6 class="mt-3">
                                    Created
                                </h6>

                                <p class="text-muted mb-0">

                                    @Model.CreatedAt.ToString("dd MMM yyyy")

                                </p>

                            </div>

                        </div>

                        <div class="col-md-4">

                            <div class="info-card">

                                <i class="bi bi-check2-square display-6 @(Model.IsCompleted ? "text-success" : "text-warning")"></i>

                                <h6 class="mt-3">

                                    Status

                                </h6>

                                <p class="mb-0">

                                    @(Model.IsCompleted ? "Completed" : "Pending")

                                </p>

                            </div>

                        </div>

                        <div class="col-md-4">

                            <div class="info-card">

                                <i class="bi bi-person-circle display-6 text-info"></i>

                                <h6 class="mt-3">

                                    Owner

                                </h6>

                                <p class="mb-0">

                                    @* @Model.User?.Name *@

                                </p>

                            </div>

                        </div>

                    </div>

                    <!-- Buttons -->

                    <div class="d-flex justify-content-between flex-wrap gap-2">

                        <a asp-controller="User"
                           asp-action="Index"
                           class="btn btn-outline-secondary">

                            <i class="bi bi-arrow-left"></i>

                            Back

                        </a>

                        <div class="d-flex gap-2">

                            @if (!Model.IsCompleted)
                            {
                                <form asp-action="UpdateStatus"
                                      asp-route-id="@Model.Id"
                                      method="post">

                                    <button class="btn btn-success">

                                        <i class="bi bi-check-circle"></i>

                                        Mark Complete

                                    </button>

                                </form>
                            }

                            <a asp-action="Edit"
                               asp-route-id="@Model.Id"
                               class="btn btn-warning">

                                <i class="bi bi-pencil"></i>

                                Edit

                            </a>

                            <form asp-action="Delete"
                                  asp-route-id="@Model.Id"
                                  method="post">

                                <button class="btn btn-danger"
                                        onclick="return confirm('Delete this task?')">

                                    <i class="bi bi-trash"></i>

                                    Delete

                                </button>

                            </form>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>