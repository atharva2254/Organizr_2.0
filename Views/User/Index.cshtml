@{
    ViewData["Title"] = "Dashboard";
}
@model User
@* @{List<Model.Tasks> tasks = new List<Model.Tasks}; *@
<div class="container py-5">

    <!-- Welcome -->

    <div class="d-flex justify-content-between align-items-center mb-5">

        <div>

            <h2 class="fw-bold">
                Hello,
                <span class="text-primary">@Model.Name👋</span>
            </h2>

            <p class="text-muted">
                Let's make today productive.
            </p>

        </div>

        @* <div>

            <img src="https://ui-avatars.com/api/?name=Atharva&background=4f46e5&color=fff&size=80"
                 class="rounded-circle shadow">

        </div> *@

    </div>


    <!-- Statistics -->

    <div class="row g-4 mb-5">

        <div class="col-lg-3">

            <div class="dashboard-card">

                <div class="d-flex justify-content-between">

                    <div>

                        <small>Total Tasks</small>

                        <h2 class="fw-bold mt-2">
                            @ViewBag.TaskCount
                        </h2>

                    </div>

                    <i class="bi bi-list-task stats-icon"></i>

                </div>

            </div>

        </div>

        <div class="col-lg-3">

            <div class="dashboard-card">

                <div class="d-flex justify-content-between">

                    <div>

                        <small>Completed</small>

                        <h2 class="text-success fw-bold mt-2">
                            @ViewBag.CompletedTask
                        </h2>

                    </div>

                    <i class="bi bi-check-circle-fill text-success display-5"></i>

                </div>

            </div>

        </div>

        <div class="col-lg-3">

            <div class="dashboard-card">

                <div class="d-flex justify-content-between">

                    <div>

                        <small>Pending</small>

                        <h2 class="text-warning fw-bold mt-2">
                            @ViewBag.PendingTask
                        </h2>

                    </div>

                    <i class="bi bi-clock-fill text-warning display-5"></i>

                </div>

            </div>

        </div>

        <div class="col-lg-3">

            <div class="dashboard-card">

                <div class="d-flex justify-content-between">

                    <div>

                        <small>Progress</small>

                        <h2 class="text-primary fw-bold mt-2">
                            67%
                        </h2>

                    </div>

                    <i class="bi bi-graph-up-arrow text-primary display-5"></i>

                </div>

            </div>

        </div>

    </div>


    <!-- Search + Button -->

    @* <div class="row mb-4">

        <div class="col-lg-9">

            <input class="form-control"
                   placeholder="🔍 Search your tasks..." />

        </div>

        <div class="col-lg-3 d-grid align-content-center">

            <a asp-controller="Task"
               asp-action="Create"
               class="btn btn-primary">

                <i class="bi bi-plus-circle"></i>

                Add New Task

            </a>

        </div>

    </div> *@


    <!-- Tasks -->

@* @model IEnumerable<Organizr.Models.TaskItem> *@

<div class="card shadow-sm border-0 rounded-4">

    <div class="card-header bg-white border-0 p-4">

        <div class="d-flex justify-content-between align-items-center">

            <div>

                <h3 class="fw-bold mb-1">
                    My Tasks
                </h3>

                <small class="text-muted">
                    @Model.Tasks.Count() Tasks
                </small>

            </div>

            <a asp-controller="Task"
               asp-action="Create"
               class="btn btn-primary">

                <i class="bi bi-plus-lg"></i>

                Add Task

            </a>

        </div>

    </div>

    <div class="card-body p-0">

        @if (Model.Tasks == null)
        {
            <div class="text-center py-5">

                <i class="bi bi-check2-square display-1 text-secondary"></i>

                <h4 class="mt-3">
                    No Tasks Yet
                </h4>

                <p class="text-muted">
                    Start by creating your first task.
                </p>

            </div>
        }
        else
        {
            @foreach (var task in Model.Tasks)
            {

                <div class="task-row px-4 py-3">

                    <div class="row align-items-center">

                        <!-- Status -->

                        <div class="col-md-1 text-center">

                            @if (task.IsCompleted)
                            {
                                <span class="status-circle completed">

                                    <i class="bi bi-check-lg"></i>

                                </span>
                            }
                            else
                            {
                                <span class="status-circle pending"></span>
                            }

                        </div>

                        <!-- Task -->

                        <div class="col-md-5">

                            <h5 class="mb-1 @(task.IsCompleted ? "text-decoration-line-through text-muted" : "")">

                                @task.Title

                            </h5>

                            <small class="text-muted">

                                @task.Description

                            </small>

                        </div>

                        <!-- Date -->

                        <div class="col-md-2">

                            <small class="text-muted">

                                @task.CreatedAt.ToString("dd MMM yyyy")

                            </small>

                        </div>

                        <!-- Status -->

                        <div class="col-md-2">

                            @if (task.IsCompleted)
                            {
                                <span class="badge bg-success">

                                    Completed

                                </span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">

                                    Pending

                                </span>
                            }

                        </div>

                        <!-- Actions -->

                        <div class="col-md-2 text-end">

                            <div class="btn-group gap-2">

                                <a asp-controller="Task"
                                   asp-action="Details"
                                   asp-route-id="@task.Id"
                                   class="btn btn-light">

                                    <i class="bi bi-eye"></i>

                                </a>

                                <a asp-controller="Task"
                                   asp-action="Edit"
                                   asp-route-id="@task.Id"
                                   class="btn btn-warning">

                                    <i class="bi bi-pencil"></i>

                                </a>

                                <form asp-action="Delete"
                                      asp-controller="Task"
                                      asp-route-id="@task.Id"
                                      method="post">

                                    <button type="submit"
                                            class="btn btn-danger"
                                            onclick="return confirm('Delete this task?');">

                                        <i class="bi bi-trash"></i>

                                    </button>

                                </form>

                            </div>

                        </div>

                    </div>

                </div>

            }
        }

    </div>

</div>

</div>